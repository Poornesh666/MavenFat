pipeline {
    agent any
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('Build') {
            steps {
                dir('mavenApp') {
                    bat 'mvn clean install'  // Changed from sh to bat
                }
            }
        }
        
        stage('Test') {
            steps {
                dir('mavenApp') {
                    bat 'mvn test'  // Changed from sh to bat
                }
            }
        }
        
        stage('Package') {
            steps {
                dir('mavenApp') {
                    bat 'mvn package'  // Changed from sh to bat
                }
            }
        }
    }
}
